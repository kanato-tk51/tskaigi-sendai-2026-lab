{
  "name": "@tskaigi-lab/adapter-eslint",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin-entry.d.ts",
      "import": "./dist/plugin-entry.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "verify:static": "node scripts/verify-static.mjs",
    "scenario:lint-only": "npm run build && node dist/local-runner.js lint-only",
    "scenario:fix": "npm run build && node dist/local-runner.js fix"
  },
  "dependencies": {
    "@tskaigi-lab/probe-core": "0.0.0",
    "eslint": "9.39.5"
  },
  "engines": {
    "node": ">=20.18.2 <21"
  }
}
