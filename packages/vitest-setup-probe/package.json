{
  "name": "@tskaigi-lab/adapter-vitest-setup",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup-entry.d.ts",
      "import": "./dist/setup-entry.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts --configLoader runner",
    "verify:static": "node scripts/verify-static.mjs",
    "scenario:run": "npm run build && node dist/local-runner.js"
  },
  "dependencies": {
    "@tskaigi-lab/probe-core": "0.0.0",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": "20.18.2",
    "npm": "11.12.1"
  }
}
