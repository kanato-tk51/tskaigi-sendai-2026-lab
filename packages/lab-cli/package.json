    "verify:static": "node scripts/verify-static.mjs",
    "scenario:fixture": "npm run build && node dist/cli-entry.js run m3-synthetic-collector"
  },
  "dependencies": {
    "@tskaigi-lab/probe-core": "0.0.0"
  },
  "engines": {
    "node": "20.18.2",
    "npm": "11.12.1"
  }
}
