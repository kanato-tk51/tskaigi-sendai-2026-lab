{
  "name": "@tskaigi-lab/adapter-npm-lifecycle",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lifecycle-entry": {
      "types": "./dist/lifecycle-entry.d.ts",
      "import": "./dist/lifecycle-entry.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "verify:static": "node scripts/verify-static.mjs"
  },
  "dependencies": {
    "@tskaigi-lab/probe-core": "0.0.0"
  },
  "engines": {
    "node": "24.18.0",
    "npm": "12.0.1"
  }
}
