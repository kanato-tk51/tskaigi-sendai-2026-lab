{
  "name": "tskaigi-sendai-2026-lab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.18.2 <21",
    "npm": "11.12.1"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --configLoader runner",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "probe-core:build": "npm run build --workspace packages/probe-core",
    "probe-core:typecheck": "npm run typecheck --workspace packages/probe-core",
    "probe-core:test": "npm run test --workspace packages/probe-core",
    "probe-core:static": "npm run verify:static --workspace packages/probe-core",
    "m2b:build": "npm run build --workspace packages/eslint-plugin-probe",
    "m2b:typecheck": "npm run typecheck --workspace packages/eslint-plugin-probe",
    "m2b:test": "npm run test --workspace packages/eslint-plugin-probe",
    "m2b:static": "npm run verify:static --workspace packages/eslint-plugin-probe",
    "m2b:run:lint": "npm run scenario:lint-only --workspace packages/eslint-plugin-probe",
    "m2b:run:fix": "npm run scenario:fix --workspace packages/eslint-plugin-probe",
    "m2b:verify": "npm run m2b:typecheck && npm run m2b:build && npm run m2b:static && npm run m2b:test",
    "m2c:build": "npm run build --workspace packages/vitest-setup-probe",
    "m2c:typecheck": "npm run typecheck --workspace packages/vitest-setup-probe",
    "m2c:test": "npm run test --workspace packages/vitest-setup-probe",
    "m2c:static": "npm run verify:static --workspace packages/vitest-setup-probe",
    "m2c:run": "npm run scenario:run --workspace packages/vitest-setup-probe",
    "m2c:verify": "npm run m2c:typecheck && npm run m2c:build && npm run m2c:static && npm run m2c:test",
    "m2a:build": "npm run build --workspace packages/npm-lifecycle-probe",
    "m2a:typecheck": "npm run typecheck --workspace packages/npm-lifecycle-probe",
    "m2a:test": "npm run test --workspace packages/npm-lifecycle-probe",
    "m2a:static": "npm run verify:static --workspace packages/npm-lifecycle-probe",
    "m2a:verify": "npm run m2a:typecheck && npm run m2a:build && npm run m2a:static && npm run m2a:test",
    "m2d:build": "npm run build --workspace packages/vite-plugin-probe",
    "m2d:typecheck": "npm run typecheck --workspace packages/vite-plugin-probe",
    "m2d:test": "npm run test --workspace packages/vite-plugin-probe",
    "m2d:static": "npm run verify:static --workspace packages/vite-plugin-probe",
    "m2d:run:observe": "npm run scenario:observe --workspace packages/vite-plugin-probe",
    "m2d:run:api": "npm run scenario:api --workspace packages/vite-plugin-probe",
    "m2d:verify": "npm run m2d:typecheck && npm run m2d:build && npm run m2d:static && npm run m2d:test",
    "m2e:build": "npm run build --workspace packages/codegen-probe",
    "m2e:typecheck": "npm run typecheck --workspace packages/codegen-probe",
    "m2e:test": "npm run test --workspace packages/codegen-probe",
    "m2e:static": "npm run verify:static --workspace packages/codegen-probe",
    "m2e:run:observe": "npm run scenario:observe --workspace packages/codegen-probe",
    "m2e:run:api": "npm run scenario:api --workspace packages/codegen-probe",
    "m2e:run:dry-run": "npm run scenario:dry-run --workspace packages/codegen-probe",
    "m2e:verify": "npm run m2e:typecheck && npm run m2e:build && npm run m2e:static && npm run m2e:test",
    "m3:build": "npm run build --workspace packages/lab-cli",
    "m3:typecheck": "npm run typecheck --workspace packages/lab-cli",
    "m3:test": "npm run test --workspace packages/lab-cli",
    "m3:static": "npm run verify:static --workspace packages/lab-cli",
    "m3:run:fixture": "npm run scenario:fixture --workspace packages/lab-cli",
    "m3:verify": "npm run m3:typecheck && npm run m3:build && npm run m3:static && npm run m3:test",
    "m4:typecheck": "tsc --project containers/profile-control/tsconfig.json --noEmit",
    "m4:static": "node containers/profile-control/scripts/verify-static.mjs",
    "m4:test": "vitest run --config containers/profile-control/vitest.config.ts --configLoader runner",
    "m4:verify": "npm run m4:typecheck && npm run m4:static && npm run m4:test",
    "m4:doctor": "tsc --project containers/profile-control/tsconfig.build.json && node containers/profile-control/dist/orchestrator-entry.js doctor",
    "m4:build": "tsc --project containers/profile-control/tsconfig.build.json && node containers/profile-control/dist/orchestrator-entry.js build",
    "m4:run:controls": "tsc --project containers/profile-control/tsconfig.build.json && node containers/profile-control/dist/orchestrator-entry.js run-controls",
    "m4:verify:evidence": "tsc --project containers/profile-control/tsconfig.build.json && node containers/profile-control/dist/orchestrator-entry.js verify",
    "m0:doctor": "node experiments/npm12-install/scripts/m0.mjs doctor",
    "m0:build": "node experiments/npm12-install/scripts/m0.mjs build",
    "m0:run": "node experiments/npm12-install/scripts/m0.mjs run",
    "m0:verify": "node experiments/npm12-install/scripts/m0.mjs verify",
    "m0:clean": "node experiments/npm12-install/scripts/m0.mjs clean"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "20.19.43",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vitest": "3.2.7"
  }
}
